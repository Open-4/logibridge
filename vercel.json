{
  "builds": [
    {
      "src": "logibridge-web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "logibridge-web/dist"
      }
    },
    {
      "src": "data-pipeline/api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/data-pipeline/api.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/logibridge-web/dist/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/logibridge-web/dist/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "/logibridge-web/dist/icons.svg"
    },
    {
      "src": "/data/(.*)",
      "dest": "/logibridge-web/dist/data/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/logibridge-web/dist/$1"
    }
  ],
  "functions": {
    "data-pipeline/api.py": {
      "runtime": "vercel-python@3.11"
    }
  }
}
